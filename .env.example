# Copy this file to .env (which is gitignored) and fill in real values.
#
#   cp .env.example .env
#   chmod 600 .env
#
# Never paste real keys into chat, screenshots, or git.
# Use a FRESH wallet for testnet; do NOT reuse mainnet keys.

# ------------------------------------------------------------------------
# Bradbury testnet — primary deployer / sponsor wallet
# ------------------------------------------------------------------------
# 0x-prefixed 32-byte hex string. Generate one with:
#   python -c "import secrets; print('0x' + secrets.token_hex(32))"
# Or import from MetaMask: Account details -> Export private key.
ACCOUNT_PRIVATE_KEY_1=0x__REPLACE_ME__

# ------------------------------------------------------------------------
# Bradbury testnet — second wallet (used by integration tests for the
# sponsor / contributor split, e.g. Charlie sponsoring Bob).
# ------------------------------------------------------------------------
ACCOUNT_PRIVATE_KEY_2=0x__REPLACE_ME__

# ------------------------------------------------------------------------
# Public address derived from ACCOUNT_PRIVATE_KEY_1.
# Used by frontend and helper scripts. NOT secret, but kept here for
# convenience so .env is the single source of truth.
# ------------------------------------------------------------------------
DEPLOYER_ADDRESS=0x__REPLACE_ME__

# ------------------------------------------------------------------------
# Optional: GitHub fine-grained PAT, READ-ONLY, public repos.
# Used as the github_token_hint in register_repo to lift GitHub's 60/h
# unauth API limit to 5000/h during scoring.
# Create at https://github.com/settings/personal-access-tokens
# ------------------------------------------------------------------------
GITHUB_TOKEN=

# ------------------------------------------------------------------------
# Filled in AFTER `genlayer deploy` succeeds.
# ------------------------------------------------------------------------
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Privy app ID (from dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=
