# Source this file before working on the contract:
#   source .envrc
#
# Or use direnv if you have it installed.

# 1. Activate the project venv (Python 3.12).
if [ -f .venv/bin/activate ]; then
  # shellcheck disable=SC1091
  . .venv/bin/activate
fi

# 2. Point genvm-lint validate / gltest direct mode at our pre-extracted SDK
#    so neither tool tries to fetch the broken v0.3.0-rc0 'latest' release.
export GENVMROOT="$HOME/.cache/genvm-shared"

# 3. Make the user-local npm prefix available (genlayer CLI lives there).
export PATH="$HOME/.npm-global/bin:$PATH"
